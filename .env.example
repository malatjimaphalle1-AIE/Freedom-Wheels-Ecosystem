# .env.example
# Wise API Configuration
# Get your API key from Wise Developer Dashboard (https://wise.com/developers/)
WISE_API_KEY=
WISE_PROFILE_ID=

# Gemini AI Configuration
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=

# Firebase Configuration (Optional override for Vercel)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# VERCEL DEPLOYMENT NOTE:
# 1. Add these variables to Vercel Dashboard -> Settings -> Environment Variables.
# 2. Re-deploy the project if you changed keys, as they are bundled during build.
