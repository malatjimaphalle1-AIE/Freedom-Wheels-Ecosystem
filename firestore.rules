// Firestore Security Rules for Freedom Wheels™ Ecosystem
// Deploy these rules to your Firebase project

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function: Check if user is the founder (MAPHALLE MALATJI)
    function isFounder() {
      return isAuth() && request.auth.token.email.lower() == 'maphalle.malatji@freedomwheels.io';
    }

    // Helper function: Check if user owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Users collection - profiles
    match /users/{userId} {
      // Anyone authenticated can read profiles
      allow read: if isAuth();

      // Users can create their own profile
      allow create: if isAuth() && isOwner(userId);

      // Users can update their own profile
      // Founders can update ANY profile (unlimited access)
      allow update: if isAuth() && (isOwner(userId) || isFounder());

      // Only founders can delete profiles
      allow delete: if isAuth() && isFounder();
    }

    // Engines collection
    match /engines/{engineId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isFounder());
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || isFounder());
    }

    // Leads collection
    match /leads/{leadId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isFounder());
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || isFounder());
    }

    // Activity logs
    match /logs/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isFounder();
      allow delete: if isFounder();
    }

    // System config - founders only
    match /config/{configId} {
      allow read: if isAuth();
      allow write: if isFounder();
    }

    // Referrals
    match /referrals/{referralId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isFounder());
      allow delete: if isFounder();
    }
  }
}

// Firebase Storage Security Rules
// Deploy these to your Firebase project storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isFounder() {
      return isAuth() && request.auth.token.email.lower() == 'maphalle.malatji@freedomwheels.io';
    }

    // Profile photos
    match /profile-photos/{userId}/{imageId} {
      allow read: if isAuth();
      allow write: if isAuth() && (userId == request.auth.uid || isFounder());
      allow delete: if isAuth() && (userId == request.auth.uid || isFounder());
    }

    // Assets - founders have unlimited access
    match /assets/{assetId} {
      allow read: if isAuth();
      allow write: if isFounder();
    }
  }
}
