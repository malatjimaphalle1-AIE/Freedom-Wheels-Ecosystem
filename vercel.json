{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/withdrawal-processor",
      "dest": "/api/withdrawal-processor"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/server"
    },
    {
      "src": "/[^.]+$",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/withdrawal-processor",
      "schedule": "0 0 * * *"
    }
  ]
}
